# frontend/.env.example — Next.js Environment Variables
# -------------------------------------------------------
# Copy to your app directory:  cp frontend/.env.example frontend/<your-app>/.env.local
#
# NEXT_PUBLIC_* vars are bundled into the browser at build time.
# NEVER put secrets, API keys, or credentials in NEXT_PUBLIC_* vars.
#
# For all other environment variables (database URLs, secrets, etc.)
# see the root .env.example file — those are backend-only.
#
# HOW NEXT.JS LOADS ENV FILES:
#   .env.local          → local dev only, never committed (gitignored)
#   .env.development    → loaded in `next dev`
#   .env.production     → loaded in `next start` and `next build`
#   .env                → all environments (commit only non-secret values)

# ── API ───────────────────────────────────────────────────────────────────────
# [REQUIRED] Base URL of the API gateway.
#            Points to the Python FastAPI service started by `make run`.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ── ENVIRONMENT ───────────────────────────────────────────────────────────────
# [OPTIONAL]
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_VERSION=1.0.0

# ── OBSERVABILITY ─────────────────────────────────────────────────────────────
# OTel Collector HTTP endpoint (browser → OTel Collector → Jaeger).
# Uses HTTP/protobuf — NOT gRPC (browsers do not support gRPC).
# docker-compose.yml exposes port 4318 for this purpose.
# [OPTIONAL]
NEXT_PUBLIC_OTEL_ENDPOINT=http://localhost:4318
NEXT_PUBLIC_OTEL_SERVICE_NAME=frontend

# ── FEATURE FLAGS ─────────────────────────────────────────────────────────────
# OpenFeature JS SDK — connects to flagd HTTP/OFREP endpoint.
# docker-compose.yml exposes flagd on port 8014.
# [OPTIONAL]
NEXT_PUBLIC_FLAGD_URL=http://localhost:8014
