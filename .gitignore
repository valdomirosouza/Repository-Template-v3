# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
dist/
build/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml
.hypothesis/

# Node.js
node_modules/
npm-debug.log*
.npm/

# Environment / secrets — never commit these
.env
.env.local
.env.*.local
*.pem
*.key
*.p12
secrets/

# IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Docker
.docker/

# Terraform
.terraform/
*.tfstate
*.tfstate.backup
.terraform.lock.hcl
terraform.tfvars

# Generated in CI — do not commit manually
sbom.cyclonedx.json
docs/site/
site/
src/shared/generated/grpc/   # generated gRPC stubs — run make gen-proto-python

# Test outputs
test-results/

# Claude Code session data — per-project memory and session-specific prompt files
.claude/memory/
resumo-*.md
*-improvement-prompt.md
*-token-efficiency-prompt.md

# Node.js lock files — regenerated on install; not committed in template
# (pnpm-lock.yaml was causing secret-scanner false positives due to hash content)
frontend/frontend/pnpm-lock.yaml

# Generated agent context graph (regenerated by `make gen-context-graph`, ADR-0057)
.agent/context-graph.json

# Per-run delivery agent state (Agentic Spec-Driven Delivery, ADR-0058)
.agent/delivery/

# Deprecated/consumed prompt & recommendation inputs (local archive, not part of the repo)
deprecated/
# …but specs/deprecated/ IS tracked — superseded specs are decision records we move there,
# never delete (skills/sdlc/spec-lifecycle.md). Carve it back out of the broad rule above.
!specs/deprecated/
!specs/deprecated/**

# Per-run /deliver dry-run outputs (plans, backlog, logs, FINAL-REPORT) — not source
reports/

# Java / Maven build output — services build per-service in services/<name>/ (ADR-0025; no root reactor pom)
services/**/target/

# OpenAPI-generator npx wrapper artifacts at repo root (the generator config is openapitools.json)
/package.json
/package-lock.json
