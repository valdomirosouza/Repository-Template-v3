{
  "__requires__": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "datasource",
      "id": "jaeger",
      "name": "Jaeger",
      "version": "1.0.0"
    },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "text", "name": "Text", "version": "" }
  ],
  "__inputs__": [
    {
      "name": "datasource",
      "label": "Prometheus Datasource",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    },
    {
      "name": "jaeger_datasource",
      "label": "Jaeger Datasource",
      "type": "datasource",
      "pluginId": "jaeger",
      "pluginName": "Jaeger"
    }
  ],
  "title": "Agent Supervision",
  "uid": "agent-supervision-v1",
  "tags": ["agents", "hitl", "supervision", "finops"],
  "schemaVersion": 36,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "agent_id",
        "label": "Agent ID",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(agent_actions_total, agent_id)",
        "refresh": 2,
        "multi": false,
        "includeAll": true,
        "allValue": ".*",
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Active HITL Queue",
      "description": "Total HITL requests currently pending human review. Alert threshold: > 50.",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 10 },
              { "color": "orange", "value": 30 },
              { "color": "red", "value": 50 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(hitl_active_requests) or vector(0)",
          "legendFormat": "Pending HITL",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "Autonomous Resolution Rate",
      "description": "Fraction of agent actions that resolved without HITL escalation (last 1h).",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.8 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "1 - clamp_min(sum(rate(hitl_approvals_total[1h])) / clamp_min(sum(rate(agent_actions_total[1h])), 1), 0)",
          "legendFormat": "Autonomous Rate",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "LLM Token Usage",
      "description": "Token consumption rate by model and type (input/output).",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 500000 },
              { "color": "red", "value": 900000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(llm_tokens_total)",
          "legendFormat": "Total Tokens",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "LLM Token Budget Remaining",
      "description": "Monthly token budget remaining. Red when < 10% left.",
      "type": "gauge",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "percentage",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 10 },
              { "color": "green", "value": 25 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "max(llm_tokens_budget_total) - sum(llm_tokens_total)",
          "legendFormat": "Budget Remaining",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "HITL Queue — Pending by Agent",
      "description": "Active HITL requests grouped by agent_id. Click agent_id to filter the dashboard.",
      "type": "table",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "displayMode": "color-background",
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": 0 },
                    { "color": "yellow", "value": 5 },
                    { "color": "red", "value": 20 }
                  ]
                }
              },
              { "id": "displayName", "value": "Pending Requests" }
            ]
          }
        ]
      },
      "options": {
        "footer": { "show": true, "reducer": ["sum"], "fields": ["Value"] },
        "sortBy": [{ "displayName": "Pending Requests", "desc": true }]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "hitl_active_requests",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "HITL Approval vs Rejection Rate",
      "description": "Rolling HITL decision rate over time. Spikes in rejections indicate agent drift.",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Approvals" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "green", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Rejections" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "red", "mode": "fixed" }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(hitl_approvals_total[5m]))",
          "legendFormat": "Approvals",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(hitl_rejections_total[5m]))",
          "legendFormat": "Rejections",
          "refId": "B"
        }
      ]
    },
    {
      "id": 4,
      "title": "HITL Wait Time Distribution",
      "description": "How long HITL requests wait before a human decides. p99 > 1h indicates queue backlog.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.50, sum(rate(hitl_wait_seconds_bucket[10m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum(rate(hitl_wait_seconds_bucket[10m])) by (le))",
          "legendFormat": "p99",
          "refId": "B"
        }
      ]
    },
    {
      "id": 5,
      "title": "Agent Actions — Success vs Failure",
      "description": "Rate of agent action outcomes filtered by $agent_id.",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "success" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "green", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "failure" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "red", "mode": "fixed" }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (result) (rate(agent_actions_total{agent_id=~\"$agent_id\"}[5m]))",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Agent Action Latency (p50 / p99)",
      "description": "End-to-end latency per agent action filtered by $agent_id.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.50, sum by (le, action_type) (rate(agent_action_duration_seconds_bucket{agent_id=~\"$agent_id\"}[5m])))",
          "legendFormat": "p50 {{action_type}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum by (le, action_type) (rate(agent_action_duration_seconds_bucket{agent_id=~\"$agent_id\"}[5m])))",
          "legendFormat": "p99 {{action_type}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 11,
      "title": "LLM Token Usage by Model",
      "description": "Token breakdown by model and type (input/output) — FinOps cost driver.",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (model, token_type) (rate(llm_tokens_total[5m]))",
          "legendFormat": "{{model}} ({{token_type}})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Jaeger — Latest Agent Trace",
      "description": "Open the latest distributed trace for the selected agent in Jaeger.",
      "type": "text",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 3 },
      "options": {
        "mode": "markdown",
        "content": "### Distributed Trace\n\nTo inspect the full decision tree for agent **`$agent_id`**, open Jaeger:\n\n→ [View traces for agent `$agent_id` in Jaeger](http://localhost:16686/search?service=template-service&tags=%7B%22agent_id%22%3A%22$agent_id%22%7D)\n\n*Replace `localhost:16686` with your Jaeger host in production.*"
      }
    }
  ]
}
