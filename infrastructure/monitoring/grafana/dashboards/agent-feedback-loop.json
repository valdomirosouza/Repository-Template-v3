{
  "__requires__": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "__inputs__": [
    {
      "name": "datasource",
      "label": "Prometheus Datasource",
      "description": "Prometheus datasource",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "title": "Agent Feedback Loop",
  "uid": "agent-feedback-loop-v1",
  "tags": ["agents", "feedback-loop", "hitl", "finops"],
  "schemaVersion": 36,
  "version": 1,
  "refresh": "60s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Active Bias Adjustments by Action Type",
      "description": "Current risk_score bias applied per action_type. 0 = no adjustment.",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 0.5,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 0.1 },
              { "color": "orange", "value": 0.3 },
              { "color": "red", "value": 0.45 }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "agent_feedback_bias_applied",
          "legendFormat": "{{action_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "HITL Rejection Rate by Action Type",
      "description": "Rejection rate observed by the feedback loop. Above 30% triggers bias increase.",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 0.2 },
              { "color": "red", "value": 0.3 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "agent_feedback_rejection_rate",
          "legendFormat": "{{action_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Total Bias Adjustments (Up vs Down)",
      "description": "Cumulative count of bias increases and decreases per action_type.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "agent_feedback_adjustments_total",
          "legendFormat": "{{action_type}} ({{direction}})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Feedback Loop Convergence — Bias Delta Over Time",
      "description": "Rate of change of bias per action_type. Near-zero = loop converging.",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(agent_feedback_adjustments_total[10m])",
          "legendFormat": "{{action_type}} ({{direction}})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "HITL Approval vs Rejection Rate (Overall)",
      "description": "Overall HITL decision balance across all action types.",
      "type": "stat",
      "gridPos": { "x": 0, "y": 16, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": 0 }]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(hitl_approvals_total)",
          "legendFormat": "Total Approvals",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(hitl_rejections_total)",
          "legendFormat": "Total Rejections",
          "refId": "B"
        }
      ]
    },
    {
      "id": 6,
      "title": "Feedback Loop Cycle Rate",
      "description": "How often the feedback loop is executing adjustments.",
      "type": "stat",
      "gridPos": { "x": 6, "y": 16, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": 0 }]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(agent_feedback_adjustments_total)",
          "legendFormat": "Total Adjustments",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Current Bias Table",
      "description": "Tabular view of all active biases with rejection rates.",
      "type": "table",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "custom": { "displayMode": "color-background" } },
        "overrides": []
      },
      "options": {
        "footer": { "show": false },
        "sortBy": [{ "displayName": "Value", "desc": true }]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "agent_feedback_bias_applied",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        }
      ]
    }
  ]
}
