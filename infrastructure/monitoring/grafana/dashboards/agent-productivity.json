{
  "__inputs": [],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "annotations": { "list": [] },
  "description": "Agent productivity — session velocity, net-new vs planned ratio, cycle time, token cost per task. Spec: specs/ai/long-running-session.md | ADR: ADR-0020 Appendix | Issue #7",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Session Velocity — Tasks Completed per Session",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "green", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "sum(rate(agent_session_tasks_total{outcome=\"completed\"}[1h])) by (task_type)",
          "legendFormat": "{{task_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Net-New vs Planned Ratio",
      "type": "piechart",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "options": {
        "pieType": "donut",
        "legend": { "displayMode": "list", "placement": "right" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "sum(agent_session_tasks_total{outcome=\"completed\"}) by (task_type)",
          "legendFormat": "{{task_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Cycle Time — spec_to_green_ci (p50 / p95)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3600 },
              { "color": "red", "value": 86400 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(agent_cycle_time_seconds_bucket{stage=\"spec_to_green_ci\"}[6h])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(agent_cycle_time_seconds_bucket{stage=\"spec_to_green_ci\"}[6h])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ]
    },
    {
      "id": 4,
      "title": "Token Cost per Completed Task (p50 / p95 tokens)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10000 },
              { "color": "red", "value": 50000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(agent_cost_per_resolution_tokens_bucket[1h])) by (action_type, le))",
          "legendFormat": "p50 {{action_type}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(agent_cost_per_resolution_tokens_bucket[1h])) by (action_type, le))",
          "legendFormat": "p95 {{action_type}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 5,
      "title": "Sub-Agent Specialization — Latency p50 / p95",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(agent_subtask_duration_seconds_bucket[5m])) by (agent_role, le))",
          "legendFormat": "p50 {{agent_role}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(agent_subtask_duration_seconds_bucket[5m])) by (agent_role, le))",
          "legendFormat": "p95 {{agent_role}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 6,
      "title": "Sub-Agent Errors by Role and Type",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "sum(rate(agent_subtask_error_total[5m])) by (agent_role, error_type)",
          "legendFormat": "{{agent_role}} / {{error_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Session Duration — p50 / p95 (seconds)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1800 },
              { "color": "red", "value": 7200 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(agent_session_duration_seconds_bucket[24h])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(agent_session_duration_seconds_bucket[24h])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ]
    },
    {
      "id": 8,
      "title": "Abandoned vs Completed Tasks",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "sum(agent_session_tasks_total{outcome=\"completed\"})",
          "legendFormat": "Completed",
          "refId": "A"
        },
        {
          "expr": "sum(agent_session_tasks_total{outcome=\"abandoned\"})",
          "legendFormat": "Abandoned",
          "refId": "B"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["agents", "productivity", "agentic-sdlc"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Agent Productivity",
  "uid": "agent-productivity",
  "version": 1
}
