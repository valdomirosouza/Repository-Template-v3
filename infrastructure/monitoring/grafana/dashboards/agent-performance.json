{
  "__inputs": [],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "annotations": { "list": [] },
  "description": "Agent MTTD, MTTR, autonomous resolution rate and cost per resolution — Spec: specs/observability/agent-performance.md",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "MTTD — p50 / p99 (seconds)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "red", "value": 60 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(agent_mttd_seconds_bucket[5m])) by (action_type, le))",
          "legendFormat": "p50 {{action_type}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(agent_mttd_seconds_bucket[5m])) by (action_type, le))",
          "legendFormat": "p99 {{action_type}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 2,
      "title": "MTTR — p50 / p99 (seconds)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 300 },
              { "color": "red", "value": 600 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(agent_mttr_seconds_bucket[5m])) by (action_type, le))",
          "legendFormat": "p50 {{action_type}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(agent_mttr_seconds_bucket[5m])) by (action_type, le))",
          "legendFormat": "p99 {{action_type}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 3,
      "title": "Autonomous Resolution Rate (target ≥ 0.80)",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.6 },
              { "color": "green", "value": 0.8 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "avg(agent_autonomous_resolution_rate) by (action_type)",
          "legendFormat": "{{action_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Cost Per Resolution — tokens p50 / p99",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "displayName": "tokens",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5000 },
              { "color": "red", "value": 10000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(agent_cost_per_resolution_tokens_bucket[5m])) by (action_type, le))",
          "legendFormat": "p50 {{action_type}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(agent_cost_per_resolution_tokens_bucket[5m])) by (action_type, le))",
          "legendFormat": "p99 {{action_type}}",
          "refId": "B"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["agent", "sre", "mttd", "mttr"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Data source",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Agent Performance (MTTD / MTTR)",
  "uid": "agent-performance-v1",
  "version": 1
}
