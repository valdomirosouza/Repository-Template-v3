{
  "__inputs": [],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "annotations": { "list": [] },
  "description": "DORA metrics dashboard — Deployment Frequency, Lead Time, Change Failure Rate, MTTR (ADR-0028)",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 7 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": { "barWidth": 0.8, "groupWidth": 0.7 },
      "targets": [
        {
          "expr": "sum(increase(dora_deployments_total{environment=\"production\",outcome=\"success\"}[30d])) by (service)",
          "legendFormat": "{{ service }} — prod (30d)",
          "refId": "A"
        },
        {
          "expr": "sum(increase(dora_deployments_total{environment=\"staging\",outcome=\"success\"}[30d])) by (service)",
          "legendFormat": "{{ service }} — staging (30d)",
          "refId": "B"
        }
      ],
      "title": "Deployment Frequency (30-day rolling)",
      "type": "barchart"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 86400 },
              { "color": "orange", "value": 604800 },
              { "color": "red", "value": 2592000 }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(dora_lead_time_seconds_bucket[30d])) by (le, service))",
          "legendFormat": "p50 — {{ service }}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.90, sum(rate(dora_lead_time_seconds_bucket[30d])) by (le, service))",
          "legendFormat": "p90 — {{ service }}",
          "refId": "B"
        }
      ],
      "title": "Lead Time for Changes (p50 / p90)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "max": 0.2,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "orange", "value": 0.1 },
              { "color": "red", "value": 0.15 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto"
      },
      "targets": [
        {
          "expr": "dora_change_failure_rate",
          "legendFormat": "{{ service }}",
          "refId": "A"
        }
      ],
      "title": "Change Failure Rate (30-day rolling, Elite < 5%)",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3600 },
              { "color": "orange", "value": 86400 },
              { "color": "red", "value": 604800 }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(dora_mttr_seconds_bucket[30d])) by (le, service))",
          "legendFormat": "p50 — {{ service }}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.90, sum(rate(dora_mttr_seconds_bucket[30d])) by (le, service))",
          "legendFormat": "p90 — {{ service }}",
          "refId": "B"
        }
      ],
      "title": "MTTR — Time to Restore Service (p50 / p90, Elite < 1h)",
      "type": "stat"
    }
  ],
  "refresh": "5m",
  "schemaVersion": 38,
  "tags": ["dora", "sre", "engineering-effectiveness"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-30d", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "DORA Metrics",
  "uid": "dora-metrics-v1",
  "version": 1
}
