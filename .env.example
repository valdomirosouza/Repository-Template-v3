# ============================================================================
# .env.example — Shared Environment Configuration
# ============================================================================
#
# HOW TO USE THIS FILE
# --------------------
# 1. Copy to .env:         cp .env.example .env
# 2. Start infrastructure:  docker compose up -d
# 3. Fill in REQUIRED values (marked [REQUIRED] — placeholders are NOT valid)
# 4. Follow your language quickstart: docs/quickstart/<your-stack>.md
#
# COMPLETE SETTINGS REFERENCE
# ---------------------------
# All available settings with their types, defaults, and validation rules are
# defined in src/shared/config.py (Pydantic Settings class). If a setting is
# not listed here it uses its coded default and does not need to appear in .env.
#
# REQUIRED vs OPTIONAL
# --------------------
# [REQUIRED] — the service will NOT start without a real value here.
# [OPTIONAL] — a sensible local-dev default is already provided.
#
# LANGUAGE QUICK REFERENCE
# -------------------------
# Python   → reads this file directly via Pydantic Settings (src/shared/config.py)
# Java     → Spring Boot maps UPPER_SNAKE_CASE vars; see Java section below
# Go       → envconfig reads vars directly; see Go section below
# Frontend → only NEXT_PUBLIC_* vars reach the browser; see Frontend section
# Jobs     → same as Python; add JOB_* vars per job in the job's README.md
#
# INTEGRATION TESTS
# -----------------
# docker-compose.test.yml offsets ports to avoid conflicts with dev services:
#   PostgreSQL  5432 → 5433
#   Redis       6379 → 6380
#   Kafka       9092 → 9093
# Use TEST_DATABASE_URL / TEST_REDIS_URL / TEST_KAFKA_BOOTSTRAP_SERVERS in CI.
#
# SECRETS
# -------
# Never commit a filled-in .env. The .gitignore already excludes it.
# Use a secrets manager (Vault, AWS Secrets Manager) in non-local environments.
# ============================================================================


# ── IDENTITY ──────────────────────────────────────────────────────────────────
# [OPTIONAL] Override SERVICE_NAME per service when running multiple locally.
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO
SERVICE_NAME=api-gateway
SERVICE_VERSION=1.0.0


# ── LOCAL ENVIRONMENT / DOCKER ────────────────────────────────────────────────
# Adoption profile used by `make smoke`: minimal | core | full
PROFILE=core
# Prevents container/network collisions with other template instances on the same
# machine. Set automatically by `make template-init`. Change if needed.
COMPOSE_PROJECT_NAME=repository-template-v2
# Port overrides — uncomment and change if the defaults conflict with other local
# services. docker-compose.yml reads these with sensible fallbacks.
# POSTGRES_PORT=5432
# REDIS_PORT=6379
# KAFKA_PORT=9092
# PROMETHEUS_PORT=9090
# GRAFANA_PORT=3001
# JAEGER_UI_PORT=16686


# ── POSTGRESQL ────────────────────────────────────────────────────────────────
# Must match POSTGRES_USER / POSTGRES_PASSWORD in docker-compose.yml.
# docker-compose.yml defaults: user=appuser  password=apppassword  db=appdb

# [OPTIONAL] Change only if you modified docker-compose.yml credentials.
POSTGRES_DB=appdb
POSTGRES_USER=appuser
POSTGRES_PASSWORD=apppassword

# Python — asyncpg driver (src/shared/db_client.py)
# [OPTIONAL]
DATABASE_URL=postgresql+asyncpg://appuser:apppassword@localhost:5432/appdb
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Java — Spring Boot property equivalents (add to your service's application.yml
#         or pass as env vars; Spring maps UPPER_SNAKE → lower.dot.notation):
#   SPRING_DATASOURCE_URL      = jdbc:postgresql://localhost:5432/appdb
#   SPRING_DATASOURCE_USERNAME = appuser
#   SPRING_DATASOURCE_PASSWORD = apppassword
#   SPRING_JPA_HIBERNATE_DDL_AUTO = validate
# Uncomment and set in your Java service .env / Helm values:
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/appdb
# SPRING_DATASOURCE_USERNAME=appuser
# SPRING_DATASOURCE_PASSWORD=apppassword

# Go — pgx / DATABASE_URL (append ?sslmode=disable for local dev)
# DATABASE_URL_GO=postgres://appuser:apppassword@localhost:5432/appdb?sslmode=disable

# Integration test database (docker-compose.test.yml — port 5433)
TEST_DATABASE_URL=postgresql+asyncpg://testuser:testpassword@localhost:5433/testdb


# ── REDIS ─────────────────────────────────────────────────────────────────────
# Must match --requirepass in docker-compose.yml (default: devpassword).
# [OPTIONAL]
REDIS_PASSWORD=devpassword
REDIS_URL=redis://:devpassword@localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# Java — Spring Boot:  SPRING_DATA_REDIS_URL=redis://localhost:6379/0
# Uncomment for Spring Boot services:
# SPRING_DATA_REDIS_URL=redis://localhost:6379/0

# Integration test Redis (docker-compose.test.yml — port 6380)
TEST_REDIS_URL=redis://localhost:6380/0

# Redis High Availability — Sentinel mode (see docs/sre/runbooks/redis-ha.md)
# [OPTIONAL] Enable when deploying to production with a Sentinel cluster.
# REDIS_SENTINEL_ENABLED=false
# REDIS_SENTINEL_MASTER_NAME=mymaster
# REDIS_SENTINEL_HOSTS=sentinel-0:26379,sentinel-1:26379,sentinel-2:26379


# ── KAFKA ─────────────────────────────────────────────────────────────────────
# [OPTIONAL]
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=api-gateway-consumer-group
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8081

# Java — Spring Boot equivalents:
#   SPRING_KAFKA_BOOTSTRAP_SERVERS            = localhost:9092
#   SPRING_KAFKA_CONSUMER_GROUP_ID            = domain-service-consumer-group
#   SPRING_KAFKA_PROPERTIES_SCHEMA_REGISTRY_URL = http://localhost:8081
# Uncomment for Spring Boot services:
# SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# SPRING_KAFKA_CONSUMER_GROUP_ID=domain-service-consumer-group

# Go — confluent-kafka-go reads KAFKA_BOOTSTRAP_SERVERS directly.

# Integration test Kafka (docker-compose.test.yml — port 9093)
TEST_KAFKA_BOOTSTRAP_SERVERS=localhost:9093


# ── AI / LLM (optional — only required when AI_AGENTS_ENABLED=true) ────────────
# AI agents are OPT-IN. Leave disabled to run the full non-AI platform with no key.
AI_AGENTS_ENABLED=false
LLM_PROVIDER=anthropic
# [REQUIRED only if AI_AGENTS_ENABLED=true] Obtain from https://console.anthropic.com/
LLM_API_KEY=placeholder-set-in-env
LLM_MODEL=claude-sonnet-4-6
# Backward-compat alias — used when LLM_API_KEY is unset/placeholder
# ANTHROPIC_API_KEY=
LLM_MAX_TOKENS=4096
LLM_TOKEN_BUDGET_PER_REQUEST=2000
LLM_CALL_TIMEOUT_SECONDS=30

# HITL gateway settings — see docs/adr/ADR-0011-hitl-hotl-model.md
# [OPTIONAL]
HITL_RISK_THRESHOLD=0.7
HITL_APPROVAL_TIMEOUT_SECONDS=300
HITL_MAX_PENDING_REQUESTS=100
HITL_REDIS_KEY_PREFIX=hitl
HITL_REDIS_TTL_GRACE_HOURS=24
HITL_EXPIRED_TTL_DAYS=7


# ── OBSERVABILITY ─────────────────────────────────────────────────────────────
# OTel Collector is started by docker-compose.yml. No changes needed for local dev.
# [OPTIONAL]
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_SERVICE_NAME=api-gateway
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=development

# OTel agent observability — OTEL-001, ADR-0043
# Controls whether llm.prompt / llm.response span events are captured on llm.inference spans.
# NEVER set to true in production — the Collector strips these events before Jaeger export,
# but defense-in-depth requires the flag to stay false at the application layer.
# [OPTIONAL]
OTEL_LLM_CAPTURE_PROMPTS=false

# Deployment environment tag forwarded to OTel Collector resource processor.
# Values: development | staging | production
# [OPTIONAL]
DEPLOYMENT_ENVIRONMENT=development

# Java — OTel Java Agent reads OTEL_* vars automatically.
#         Add -javaagent:opentelemetry-javaagent.jar to JAVA_TOOL_OPTIONS:
#   JAVA_TOOL_OPTIONS=-javaagent:/opt/otel/opentelemetry-javaagent.jar
# Uncomment for Java services:
# JAVA_TOOL_OPTIONS=-javaagent:/opt/otel/opentelemetry-javaagent.jar

# Go — OTel SDK reads OTEL_EXPORTER_OTLP_ENDPOINT automatically when initialized.

# Frontend — browser SDK uses HTTP (not gRPC):
# [OPTIONAL] copy to frontend/<app>/.env.local
NEXT_PUBLIC_OTEL_ENDPOINT=http://localhost:4318

# Prometheus and Jaeger UIs — no env vars needed for local dev.
#   Prometheus   → http://localhost:9090
#   Jaeger UI    → http://localhost:16686
#   Grafana      → http://localhost:3001  (admin / admin)
#   Alertmanager → http://localhost:9093
PROMETHEUS_PORT=9090

# Alertmanager → PagerDuty integration (REM-002, REM-014)
# [REQUIRED in staging/prod] Generate at: Services → Integrations → Events API v2
# Leave as placeholder in local dev (alerts are silently dropped by the "null" receiver).
PAGERDUTY_INTEGRATION_KEY=placeholder-set-in-env


# ── FEATURE FLAGS ─────────────────────────────────────────────────────────────
# OpenFeature + flagd — see infrastructure/feature-flags/README.md
# flagd is started by docker-compose.yml. No changes needed for local dev.
# [OPTIONAL]
FEATURE_FLAG_PROVIDER=flagd
FEATURE_FLAG_SDK_KEY=local-dev-key
FLAGD_HOST=localhost
FLAGD_PORT=8013

# Fallback if flagd is unreachable. Set to false always — HOTL mode requires
# explicit governance approval (ADR-0015).
# [OPTIONAL]
AUTONOMOUS_MODE_ENABLED=false


# ── SECURITY ──────────────────────────────────────────────────────────────────
# [REQUIRED] Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-this-with-a-real-32-character-secret-before-running

# AES-256-GCM key for database at-rest encryption (ADR-0018).
# Must be exactly 64 lowercase hex characters (32 bytes).
# [REQUIRED in production] Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# In production this is injected by Vault Agent (ADR-0008) — never commit a real key.
# Set DB_ENCRYPTION_ENABLED=false only in local dev without Vault.
DB_ENCRYPTION_KEY=placeholder-set-in-env
DB_ENCRYPTION_ENABLED=false

# Redis TLS (ADR-0019). Set REDIS_TLS_ENABLED=true in all non-local environments.
# In production, also change REDIS_URL scheme to rediss://.
# REDIS_TLS_CA_CERT: path to CA cert file; leave empty to use system CAs.
# [REQUIRED in production]
REDIS_TLS_ENABLED=false
REDIS_TLS_CA_CERT=

# [OPTIONAL]
JWT_ALGORITHM=HS256
JWT_EXPIRY_SECONDS=3600

# Comma-separated allowed CORS origins. Add your frontend dev server here.
# [OPTIONAL]
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Rate limiting applied per IP by slowapi.
# [OPTIONAL]
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Outbound SSRF allow-list (OWASP A10). Comma-separated hosts that server-side outbound requests
# may target (exact or .dot-suffix). Empty = no host restriction, but metadata/link-local
# endpoints and non-http(s) schemes are blocked regardless. e.g. api.anthropic.com,.internal.example.com
# [OPTIONAL]
OUTBOUND_URL_ALLOWLIST=


# ── PRIVACY ───────────────────────────────────────────────────────────────────
# See docs/privacy/pii-inventory.md for L1–L4 classification levels.
# Disabling PII masking in production is blocked by the guardrails layer.
# [OPTIONAL]
PII_MASKING_ENABLED=true
PII_AUDIT_LOG_ENABLED=true
DATA_RETENTION_DAYS=30


# ── FINOPS ────────────────────────────────────────────────────────────────────
# Monthly LLM token budget. Cost alert fires at COST_ALERT_THRESHOLD_USD.
# [OPTIONAL]
LLM_MONTHLY_TOKEN_BUDGET=1000000
COST_ALERT_THRESHOLD_USD=100.0


# ── FRONTEND (Next.js) ────────────────────────────────────────────────────────
# NEXT_PUBLIC_* vars are bundled into the browser at build time.
# NEVER put secrets or API keys in NEXT_PUBLIC_* vars.
# Copy these into frontend/<your-app>/.env.local for the Next.js dev server.
#
# [REQUIRED for frontend developers]
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_APP_ENV=development
# [OPTIONAL]
NEXT_PUBLIC_OTEL_SERVICE_NAME=frontend


# ── JAVA / SPRING BOOT ────────────────────────────────────────────────────────
# Spring Boot reads environment variables by uppercasing and replacing dots with
# underscores (relaxed binding). Example:
#   spring.application.name → SPRING_APPLICATION_NAME
#
# Copy and adapt these per Java service. Database, Redis, and Kafka vars above
# are already read; only Spring-specific overrides belong here.
# [OPTIONAL] — uncomment in your Java service's environment or application.yml:
# SPRING_APPLICATION_NAME=domain-service
# SERVER_PORT=8080
# SPRING_PROFILES_ACTIVE=development
# MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,readiness,liveness,prometheus,info


# ── GO WORKERS ────────────────────────────────────────────────────────────────
# Go services use envconfig — all vars above are read directly.
# Add worker-specific vars per service as needed.
# [OPTIONAL]
# WORKER_BATCH_SIZE=500
# WORKER_CONCURRENCY=10
# WORKER_POLL_INTERVAL_SECONDS=5


# ── JOBS / BATCH WORKERS ──────────────────────────────────────────────────────
# Scheduled jobs use the Python stack. See docs/quickstart/jobs-worker.md.
# Add per-job vars in the job's own README.md, not here.
# [OPTIONAL]
JOB_SCHEDULE_CRON=0 2 * * *
JOB_BATCH_SIZE=500
JOB_MAX_RETRIES=3
